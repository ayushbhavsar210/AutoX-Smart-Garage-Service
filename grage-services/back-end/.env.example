# ==========================
# Production Environment
# ==========================

# Server Configuration
PORT=5000
NODE_ENV=production

# ==========================
# Database Configuration
# ==========================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority&appName=AutoX
MONGODB_DB_NAME=autox

# ==========================
# Frontend Configuration
# ==========================
# Primary frontend URL (Vercel)
FRONTEND_URL=https://auto-x-smart-garage-service.vercel.app

# Comma-separated list of allowed frontend origins
# Include all preview deployments and custom domains
FRONTEND_ALLOWED_ORIGINS=https://auto-x-smart-garage-service.vercel.app,https://auto-x-smart-garage-service-*.vercel.app

# ==========================
# Payment Gateway (Razorpay)
# ==========================
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ==========================
# Email Configuration
# ==========================
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-specific-password

# ==========================
# Optional: Render Deployment
# ==========================
# Automatically set by Render, override if needed:
# RENDER_EXTERNAL_URL=https://your-backend-url.onrender.com

# ==========================
# IMPORTANT PRODUCTION NOTES
# ==========================
# 1. ✅ NO localhost URLs in production
# 2. ✅ All URLs must use HTTPS (secure)
# 3. ✅ FRONTEND_ALLOWED_ORIGINS must include all frontend domains
# 4. ✅ Keep sensitive keys in environment variables
# 5. ✅ Never commit .env to git (use .gitignore)
# 6. ✅ Use Vercel/Render UI for environment management
# 7. ✅ Email password should be app-specific (Gmail)
# 8. ✅ Razorpay keys must be production keys (rzp_live_*)
# 9. ✅ MongoDB must allow connections from Render IP
# 10. ✅ Enable gzip compression (done in server.js)
